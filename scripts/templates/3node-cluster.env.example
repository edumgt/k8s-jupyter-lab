# Kubernetes bootstrap template (control-plane + worker1/2/3)
# Usage:
#   cp scripts/templates/3node-cluster.env.example /tmp/3node-cluster.env
#   vi /tmp/3node-cluster.env
#   bash scripts/bootstrap_3node_k8s_ova.sh --config /tmp/3node-cluster.env

# SSH auth (choose one of password/key)
SSH_USER=ubuntu
SSH_PASSWORD=ubuntu
# SSH_KEY_PATH=/home/you/.ssh/id_rsa
SSH_PORT=22

# Control-plane node
CONTROL_PLANE_SSH_HOST=192.168.56.10
CONTROL_PLANE_HOSTNAME=k8s-data-platform
CONTROL_PLANE_IP=192.168.56.10

# Worker-1
WORKER1_SSH_HOST=192.168.56.11
WORKER1_HOSTNAME=k8s-worker-1
WORKER1_IP=192.168.56.11

# Worker-2
WORKER2_SSH_HOST=192.168.56.12
WORKER2_HOSTNAME=k8s-worker-2
WORKER2_IP=192.168.56.12

# Worker-3 (optional; leave empty to run without worker-3)
WORKER3_SSH_HOST=192.168.56.13
WORKER3_HOSTNAME=k8s-worker-3
WORKER3_IP=192.168.56.13

# Static network setup
NETWORK_CIDR_PREFIX=24
GATEWAY=192.168.56.1
# Prefer gateway DNS first to reduce image pull DNS timeout in local VM networks.
DNS_SERVERS=192.168.56.1,1.1.1.1,8.8.8.8
# Leave empty to auto-detect default route interface (ex: ens33/ens160)
NET_INTERFACE=

# kubeadm join token
TOKEN_TTL=2h

# Workload apply
APPLY_OVERLAY=1
ENVIRONMENT=dev
OVERLAY=dev-3node
REMOTE_REPO_ROOT=/opt/k8s-data-platform

# Optional ingress URL stack (NGINX Ingress + MetalLB)
SETUP_INGRESS_STACK=1
# Leave empty to auto-calculate from CONTROL_PLANE_IP (/24 => .240-.250)
METALLB_ADDRESS_RANGE=
# Leave empty to auto-select the first pool IP (.240)
INGRESS_LB_IP=
# Advanced: local file path or URL override
METALLB_MANIFEST=
INGRESS_MANIFEST=

# Optional skips
SKIP_NETWORK=0
SKIP_JOIN=0
